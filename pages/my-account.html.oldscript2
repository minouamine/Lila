                        <div class="upgrade-notice" style="margin-top:10px;">
                            ${lang === 'fr'
                                ? 'Passez au <strong>Platine</strong> et économisez 33% — <a onclick="onUpgradeButtonClick()">Passer à Platine 💎</a>'
                                : 'رقّي إلى <strong>البلاتيني</strong> ووفّري 33% — <a onclick="onUpgradeButtonClick()">الترقية إلى بلاتيني 💎</a>'}
                        </div>`;
