                { icon: '📅', ar: 'استقبال حجوزات (3 يومياً)', fr: 'Réservations (3/jour)', locked: false },
                { icon: '👤', ar: 'إدارة الملف الشخصي', fr: 'Gestion du profil', locked: false },
                { icon: '📊', ar: 'لوحة تحليل الحساب', fr: 'Tableau analytique', locked: true },
                { icon: '📖', ar: 'قصص 24 ساعة', fr: 'Stories 24h', locked: true },
                { icon: '🏷️', ar: 'إطلاق تخفيضات', fr: 'Lancer des promotions', locked: true },
                { icon: '🔔', ar: 'إشعارات للمتابعات', fr: 'Notifications abonnées', locked: true },
            ];
            const featuresFromGold = [
                { icon: '📅', ar: 'حجوزات غير محدودة', fr: 'Réservations illimitées', locked: false },
                { icon: '📊', ar: 'لوحة تحليل الحساب', fr: 'Tableau analytique', locked: false },
                { icon: '📖', ar: 'قصص 24 ساعة', fr: 'Stories 24h', locked: false },
                { icon: '🏷️', ar: 'إطلاق تخفيضات', fr: 'Lancer des promotions', locked: false },
