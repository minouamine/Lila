                                ${f.locked ? `<span style="margin-right:auto;font-size:0.7rem;color:#f87171;">🔒 ${lang === 'fr' ? 'Verrouillé' : 'محجوب'}</span>` : ''}
                            </div>`).join('')}
                    </div>
                    <button class="go-dashboard-btn ${btnClass}"
                        onclick="window.location.href='business-dashboard.html'"
                        data-ar="🚀 الدخول إلى لوحة التحكم" data-fr="🚀 Accéder au tableau de bord">
                        🚀 الدخول إلى لوحة التحكم
                    </button>
                    ${upgradeSection}
                </div>`;
            if (window.lang) window.lang.updateAllTranslations();
        }

        // --- إعدادات ---
        else if (activeTab === 'settings') {
            container.innerHTML = `
                <div class="edit-form">
                    <h3 data-ar="إعدادات الحساب" data-fr="Paramètres du compte">إعدادات الحساب</h3>

                    <!-- البريد الإلكتروني — هنا فقط -->
                    <div class="form-group">
                        <label data-ar="البريد الإلكتروني" data-fr="Adresse e-mail">البريد الإلكتروني</label>
                        <div class="email-display">${DOMPurify.sanitize(userProfile.email || '—')}</div>
                    </div>

                    <div class="form-group">
                        <label data-ar="الاسم الكامل" data-fr="Nom complet">الاسم الكامل</label>
                        <input type="text" id="fullName"
                            value="${DOMPurify.sanitize(userProfile.full_name || '')}"
                            placeholder="${lang === 'fr' ? 'Votre nom' : 'اسمك كاملاً'}"
                            maxlength="30">
                        <span id="fullNameError" class="field-error-msg" style="display:none;"></span>
                    </div>

                    <div class="form-group">
                        <label data-ar="صورة الملف الشخصي" data-fr="Photo de profil">صورة الملف الشخصي</label>
                        <div style="display:flex;align-items:center;gap:12px;margin-top:8px;">
                            <img id="avatarPreview"
                                src="${userProfile.avatar_url || '../assets/images/default-avatar.png'}"
                                onerror="this.src='../assets/images/default-avatar.png'"
                                style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:2px solid var(--accent-orange);">
                            <input type="file" id="avatarFile" accept="image/jpeg,image/png,image/webp,image/gif" style="flex:1;">
                        </div>
                        <span id="avatarError" class="field-error-msg" style="display:none;"></span>
                    </div>

                    <button class="save-btn" id="saveSettingsBtn" onclick="onSaveSettings()"
                        data-ar="💾 حفظ التغييرات" data-fr="💾 Enregistrer">💾 حفظ التغييرات</button>

                    <div style="margin-top:30px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.1);text-align:center;">
                        <a href="../pages/support.html" style="color:var(--red);text-decoration:underline;font-size:14px;"
                            data-ar="حذف الحساب — تواصلي مع الدعم" data-fr="Supprimer le compte — Contacter le support">
                            حذف الحساب — تواصلي مع الدعم
                        </a>
                    </div>
                </div>`;

            const avatarFileInput = document.getElementById('avatarFile');
            if (avatarFileInput) {
                avatarFileInput.addEventListener('change', (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    const allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
                    const avatarError = document.getElementById('avatarError');
                    if (!allowed.includes(file.type)) {
                        avatarError.textContent = lang === 'fr'
                            ? 'Format non autorisé. Utilisez JPG, PNG, WEBP ou GIF.'
                            : 'نوع الملف غير مسموح. استخدمي JPG أو PNG أو WEBP أو GIF.';
                        avatarError.style.display = 'block';
                        avatarFileInput.value = '';
                        return;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        avatarError.textContent = lang === 'fr'
                            ? "La taille de l'image ne doit pas dépasser 5 Mo."
                            : 'حجم الصورة يجب ألا يتجاوز 5 ميجابايت.';
                        avatarError.style.display = 'block';
                        avatarFileInput.value = '';
                        return;
                    }
                    avatarError.style.display = 'none';
                    document.getElementById('avatarPreview').src = URL.createObjectURL(file);
                });
            }
            if (window.lang) window.lang.updateAllTranslations();
        }
    }

    // ========================================
    // التحقق من صحة الاسم
    // ========================================
    function validateFullName(name, lang) {
        const errorEl = document.getElementById('fullNameError');
        const isFr = lang === 'fr';
        if (!name || name.trim().length === 0) {
            errorEl.textContent = isFr ? 'Le nom ne peut pas être vide.' : 'الاسم لا يمكن أن يكون فارغاً.';
            errorEl.style.display = 'block'; return false;
        }
        if (name.trim().length < 3) {
            errorEl.textContent = isFr ? 'Le nom doit contenir au moins 3 caractères.' : 'الاسم يجب أن يحتوي على 3 حروف على الأقل.';
            errorEl.style.display = 'block'; return false;
        }
        if (name.trim().length > 30) {
            errorEl.textContent = isFr ? 'Le nom ne doit pas dépasser 30 caractères.' : 'الاسم يجب ألا يتجاوز 30 حرفاً.';
            errorEl.style.display = 'block'; return false;
        }
        const nameRegex = /^[a-zA-Z0-9_\u0600-\u06FF\s]{3,30}$/;
        if (!nameRegex.test(name.trim())) {
            errorEl.textContent = isFr
                ? 'Le nom ne peut contenir que des lettres, chiffres, espaces et underscores.'
                : 'الاسم يجب أن يحتوي على حروف وأرقام ومسافات وشرطة سفلية فقط. لا رموز خاصة.';
            errorEl.style.display = 'block'; return false;
        }
        if (window.utils && window.utils.containsProfanity(name, lang === 'fr' ? 'fr' : 'ar')) {
            errorEl.textContent = isFr ? 'Ce nom contient des mots inappropriés.' : 'الاسم يحتوي على كلمات غير لائقة.';
            errorEl.style.display = 'block'; return false;
        }
        errorEl.style.display = 'none';
        return true;
    }

    // ========================================
    // معالجة الضغط على زر الترقية
    // ========================================
    function onUpgradeButtonClick() {
        const lang = window.lang ? window.lang.getCurrentLang() : 'ar';
        if (userProfile.user_type !== 'business') { window.location.href = 'business-register.html'; return; }
        const tier = businessProfile?.subscription_tier || 'silver';
        if (tier === 'platinum') return;
        const targetTier = tier === 'gold' ? 'platinum' : 'gold';
        const amount = targetTier === 'gold' ? 3000 : 6000;
        const tierLabelAr = targetTier === 'gold' ? 'الذهبي 🥇' : 'البلاتيني 💎';
        const tierLabelFr = targetTier === 'gold' ? 'Gold 🥇' : 'Platinum 💎';
        const message = lang === 'fr'
            ? `Voulez-vous passer à l'abonnement ${tierLabelFr} pour ${amount.toLocaleString('fr-FR')} DZD ?`
            : `هل تريدين الترقية إلى الاشتراك ${tierLabelAr} مقابل ${amount.toLocaleString('ar-DZ')} د.ج؟`;
        if (confirm(message)) {
            localStorage.setItem('upgrade_target_tier', targetTier);
            localStorage.setItem('upgrade_amount', amount);
            window.location.href = 'upgrade.html';
        }
    }
    window.onUpgradeButtonClick = onUpgradeButtonClick;

    // ========================================
    // ضغط الصورة قبل الرفع
    // ========================================
    async function compressAvatarImage(file) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = function () {
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                const maxSize = 512;
                if (w > maxSize) { h = (h * maxSize) / w; w = maxSize; }
                if (h > maxSize) { w = (w * maxSize) / h; h = maxSize; }
                canvas.width = Math.round(w);
                canvas.height = Math.round(h);
                canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
                canvas.toBlob(blob => {
                    if (blob) resolve(blob);
                    else reject(new Error('Compression failed'));
                }, 'image/jpeg', 0.8);
            };
            img.onerror = () => reject(new Error('Failed to load image'));
            img.src = URL.createObjectURL(file);
        });
    }

    // ========================================
    // حفظ إعدادات المستخدم
    // ========================================
    window.onSaveSettings = async function () {
        const lang = window.lang ? window.lang.getCurrentLang() : 'ar';
        const fullNameRaw = document.getElementById('fullName')?.value || '';
        const avatarFile = document.getElementById('avatarFile')?.files[0];
        const saveBtn = document.getElementById('saveSettingsBtn');
        if (!validateFullName(fullNameRaw, lang)) return;
        const fullName = window.utils
            ? window.utils.sanitizeText(fullNameRaw.trim(), lang === 'fr' ? 'fr' : 'ar')
            : DOMPurify.sanitize(fullNameRaw.trim());
        if (saveBtn) saveBtn.disabled = true;
        try {
            const updates = { full_name: fullName, updated_at: new Date() };
            if (avatarFile) {
                const compressedBlob = await compressAvatarImage(avatarFile);
                const fileName = `${userProfile.id}_${Date.now()}.jpg`;
                const newAvatarUrl = await window.lilaAPI.uploadFile('avatars', fileName, compressedBlob);
                updates.avatar_url = newAvatarUrl;
            }
            await supabaseClient.from('profiles').update(updates).eq('id', userProfile.id);
            userProfile.full_name = updates.full_name;
            if (updates.avatar_url) userProfile.avatar_url = updates.avatar_url;
            if (window.utils) window.utils.showToast(lang === 'fr' ? 'Profil mis à jour' : 'تم تحديث الملف الشخصي', 'success');
            await renderAccountUI();
        } catch (error) {
            console.error('Error saving settings:', error);
            if (window.utils) window.utils.showToast(lang === 'fr' ? 'Erreur lors de la mise à jour' : 'حدث خطأ أثناء التحديث', 'error');
        } finally {
            if (saveBtn) saveBtn.disabled = false;
        }
    };

    // ========================================
    // نص الحالة مترجم
    // ========================================
    function getStatusText(status, lang) {
        const map = {
            pending:   { ar: 'قيد الانتظار', fr: 'En attente' },
            confirmed: { ar: 'مؤكد',         fr: 'Confirmé' },
            completed: { ar: 'مكتمل',        fr: 'Terminé' },
            cancelled: { ar: 'ملغي',          fr: 'Annulé' }
        };
        return map[status]?.[lang] ?? status;
    }

    // ========================================
    // تحديث اللغة
    // ========================================
    async function onLanguageChange() {
        if (userProfile) await renderAccountUI();
        else renderLoginPrompt();
    }

    // ========================================
    // مودال المطورة
    // ========================================
    function initDevModal() {
        const devModal = document.getElementById('devModal');
        const openBtn = document.getElementById('openDevBtn');
        const closeBtn = document.getElementById('closeModalBtn');
        if (openBtn) openBtn.addEventListener('click', () => devModal.classList.add('show'));
        if (closeBtn) closeBtn.addEventListener('click', () => devModal.classList.remove('show'));
        if (devModal) devModal.addEventListener('click', e => { if (e.target === devModal) devModal.classList.remove('show'); });
    }

    // ========================================
    // موسيقى الخلفية
    // ========================================
    function initMusicToggle() {
        const musicBtn = document.getElementById('musicToggleBtn');
        let audio = null, playing = false;
        if (musicBtn) {
            musicBtn.addEventListener('click', () => {
                if (!audio) { audio = new Audio('../assets/music/bg.mp3'); audio.loop = true; audio.volume = 0.3; }
                if (playing) { audio.pause(); musicBtn.textContent = '🔇'; }
                else { audio.play().catch(() => {}); musicBtn.textContent = '🔊'; }
                playing = !playing;
            });
        }
    }

    // ========================================
    // التهيئة عند تحميل الصفحة
    // ========================================
    async function initPage() {
        initDevModal();
        initMusicToggle();
        await loadUserData();
        if (window.lang) {
            window.lang.addLangListener(onLanguageChange);
            window.lang.updateAllTranslations();
        }
        if (window.particles && typeof window.particles.init === 'function') window.particles.init();
        if (window.auth && typeof window.auth.addAuthListener === 'function') {
            window.auth.addAuthListener(() => { loadUserData(); });
        }
        console.log('[MyAccount] Page initialized successfully');
    }

    document.addEventListener('DOMContentLoaded', initPage);
</script>
</body>
</html>
