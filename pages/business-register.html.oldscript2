<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>إنشاء حساب تجاري - ليلى</title>
    <link rel="stylesheet" href="../css/main.css">
    <style>
        /* أنماط إضافية لصفحة التسجيل */
        .register-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .form-section {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid var(--border-subtle);
        }
        
        .form-section h2 {
            font-size: 1.3rem;
            margin-bottom: 20px;
            color: var(--accent-orange);
            border-right: 3px solid var(--accent-orange);
            padding-right: 12px;
        }
        
        .form-group {
            margin-bottom: 18px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-secondary);
        }
        
        .form-group label .required {
            color: var(--red);
            margin-right: 4px;
        }
        
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            background: rgba(4, 8, 16, 0.8);
            border: 1px solid var(--border-active);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: var(--font-arabic);
            font-size: 0.95rem;
        }
        
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--accent-orange);
            box-shadow: 0 0 0 3px var(--glow-orange);
        }

        .form-group input.input-error {
            border-color: #ef4444;
        }
        
        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 8px;
        }
        
        .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: normal;
            cursor: pointer;
        }
        
        .checkbox-group input {
            width: auto;
            transform: scale(1.1);
        }
        
        .image-upload {
            border: 2px dashed var(--border-active);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .image-upload:hover {
            border-color: var(--accent-orange);
            background: rgba(255,140,0,0.05);
        }
        
        .image-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }
        
        .image-preview img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid var(--border-active);
        }
        
        .location-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        
        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--accent-orange), #ff4500);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px var(--glow-orange);
        }

        .btn-submit:disabled {
            opacity: 0.45;
            cursor: not-allowed;
            transform: none;
            filter: grayscale(0.4);
        }
        
        .btn-back {
            display: inline-block;
            margin-bottom: 20px;
            color: var(--accent-orange);
            text-decoration: none;
            font-weight: 600;
        }
        
        .btn-back:hover {
            text-decoration: underline;
        }
        
        .progress-bar {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            position: relative;
        }
        
        .progress-step {
            flex: 1;
            text-align: center;
            position: relative;
            z-index: 1;
        }
        
        .progress-step .step-number {
            width: 40px;
            height: 40px;
            background: var(--bg-surface);
            border: 2px solid var(--border-active);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px;
            font-weight: bold;
        }
        
        .progress-step.active .step-number {
            background: var(--accent-orange);
            border-color: var(--accent-orange);
            color: white;
        }
        
        .progress-step.completed .step-number {
            background: var(--green);
            border-color: var(--green);
            color: white;
        }

        .progress-step.completed .step-number::after {
            content: '✓';
        }
        
        .progress-line {
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--border-active);
            z-index: 0;
        }
        
        .form-step {
            display: none;
        }
        
        .form-step.active-step {
            display: block;
        }
        
        .step-buttons {
            display: flex;
            justify-content: space-between;
            margin-top: 24px;
        }
        
        .btn-next, .btn-prev {
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }
        
        .btn-next {
            background: var(--accent-orange);
            border: none;
            color: white;
        }
        
        .btn-prev {
            background: transparent;
            border: 1px solid var(--border-active);
            color: var(--text-secondary);
        }

        .field-error-msg {
            color: #ef4444;
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }

        .field-hint {
            color: var(--text-dim);
            font-size: 11px;
            margin-top: 4px;
            display: block;
        }
        
        @media (max-width: 600px) {
            .location-row {
                grid-template-columns: 1fr;
            }
            .checkbox-group {
                flex-direction: column;
                gap: 8px;
            }
        }
    </style>
</head>
<body>

<canvas id="particleCanvas" class="particle-canvas"></canvas>
<div class="scanline-overlay"></div>

<div class="app">
    <div class="header">
        <div class="header-grid-lines"></div>
        <div class="app-title">
            <span class="title-line"></span>
            <span class="title-ar">إنشاء حساب تجاري</span>
            <span class="title-line"></span>
        </div>
        <div class="header-sub">انضمي إلى دليل ليلى</div>
    </div>

    <div class="main-content">
        <div class="register-container">
            <a href="../index.html" class="btn-back">← العودة إلى الرئيسية</a>
            
            <!-- Progress Bar -->
            <div class="progress-bar">
                <div class="progress-line"></div>
                <div class="progress-step active" data-step="1">
                    <div class="step-number">1</div>
                    <div>نوع الحساب</div>
                </div>
                <div class="progress-step" data-step="2">
                    <div class="step-number">2</div>
                    <div>المعلومات الأساسية</div>
                </div>
                <div class="progress-step" data-step="3">
                    <div class="step-number">3</div>
                    <div>الموقع والعنوان</div>
                </div>
                <div class="progress-step" data-step="4">
                    <div class="step-number">4</div>
                    <div>التوثيق</div>
                </div>
            </div>
            
            <form id="businessRegisterForm">
                <!-- Step 1: نوع الحساب -->
                <div class="form-step active-step" data-step="1">
                    <div class="form-section">
                        <h2>📌 ما نوع الخدمات التي تقدمينها؟</h2>
                        <div class="checkbox-group" id="servicesGroup">
                            <label><input type="checkbox" value="salon_hair"> صالون حلاقة</label>
                            <label><input type="checkbox" value="salon_beauty"> صالون تجميل</label>
                            <label><input type="checkbox" value="home_hair"> حلاقة في منزلي</label>
                            <label><input type="checkbox" value="mobile_hair"> حلاقة مع التنقل</label>
                            <label><input type="checkbox" value="product_seller"> بائعة منتجات</label>
                            <label><input type="checkbox" value="dress_rental"> تأجير أزياء</label>
                            <label><input type="checkbox" value="home_service"> خدمات منزلية</label>
                        </div>
                        <span id="servicesError" class="field-error-msg" style="display:none;"></span>
                    </div>
                    
                    <div class="form-section">
                        <h2>💰 الاشتراك</h2>
                        <div class="checkbox-group">
                            <label><input type="radio" name="subscription" value="silver" checked> 🥈 فضي - 0 دج (3 حجوزات/يوم)</label>
                            <label><input type="radio" name="subscription" value="gold"> 🥇 ذهبي - 3000 دج/3 أشهر</label>
                            <label><input type="radio" name="subscription" value="platinum"> 💎 بلاتيني - 6000 دج/6 أشهر</label>
                        </div>
                    </div>
                    
                    <div class="step-buttons">
                        <button type="button" class="btn-next" onclick="nextStep()">التالي →</button>
                    </div>
                </div>
                
                <!-- Step 2: المعلومات الأساسية -->
                <div class="form-step" data-step="2">
                    <div class="form-section">
                        <h2>🏢 معلومات الحساب</h2>
                        <div class="form-group">
                            <label>اسم الحساب التجاري <span class="required">*</span></label>
                            <input type="text" id="businessName" maxlength="50" placeholder="مثال: صالون نسمة">
                            <span class="field-hint">بين 3 و50 حرفاً، حروف وأرقام ومسافات فقط. لا رموز خاصة.</span>
                            <span id="businessNameError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>اسم المستخدم <span class="required">*</span></label>
                            <input type="text" id="username" maxlength="30" placeholder="بين 3 و30 حرف، أحرف وأرقام وشرطة سفلية فقط">
                            <span class="field-hint">مثال: salon_nesma — لا مسافات، لا رموز خاصة</span>
                            <span id="usernameError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>وصف قصير (BIO) <span class="required">*</span></label>
                            <textarea id="bio" rows="3" maxlength="500" placeholder="وصف خدماتك، خبراتك، مميزاتك... (لا يتعدى 500 حرف)"></textarea>
                            <small id="bioCount" style="color:var(--text-dim);">0 / 500</small>
                            <span id="bioError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>رقم الهاتف</label>
                            <input type="tel" id="phone" placeholder="05XX XX XX XX" maxlength="10">
                            <span class="field-hint">مثال: 0555123456 — أرقام جزائرية فقط (05/06/07)</span>
                            <span id="phoneError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>واتساب</label>
                            <input type="tel" id="whatsapp" placeholder="05XX XX XX XX" maxlength="10">
                            <span class="field-hint">مثال: 0555123456 — أرقام جزائرية فقط (05/06/07)</span>
                            <span id="whatsappError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>رابط Instagram (اختياري)</label>
                            <input type="url" id="instagram" placeholder="https://instagram.com/اسمك">
                            <span class="field-hint">يجب أن يبدأ بـ https://instagram.com/ أو https://www.instagram.com/</span>
                            <span id="instagramError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>رابط TikTok (اختياري)</label>
                            <input type="url" id="tiktok" placeholder="https://tiktok.com/@اسمك">
                            <span class="field-hint">يجب أن يبدأ بـ https://tiktok.com/ أو https://www.tiktok.com/</span>
                            <span id="tiktokError" class="field-error-msg" style="display:none;"></span>
                        </div>
                        <div class="form-group">
                            <label>رابط Facebook (اختياري)</label>
                            <input type="url" id="facebook" placeholder="https://facebook.com/اسمك">
                            <span class="field-hint">يجب أن يبدأ بـ https://facebook.com/ أو https://www.facebook.com/</span>
                            <span id="facebookError" class="field-error-msg" style="display:none;"></span>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h2>📸 صور الحساب</h2>
                        <div class="form-group">
                            <label>صورة الحساب (لوجو)</label>
                            <div class="image-upload" id="logoUpload">
                                <span>📷 اضغطي لرفع صورة</span>
                                <input type="file" id="logoFile" accept="image/jpeg,image/png,image/webp" style="display:none;">
                            </div>
                            <div class="image-preview" id="logoPreview"></div>
                        </div>
                        <div class="form-group">
                            <label>صور وصفية للحساب</label>
                            <div class="image-upload" id="galleryUpload">
                                <span>📷 اضغطي لرفع صور متعددة</span>
                                <input type="file" id="galleryFiles" accept="image/jpeg,image/png,image/webp" multiple style="display:none;">
                            </div>
                            <div class="image-preview" id="galleryPreview"></div>
                        </div>
                        <div class="form-group">
                            <label>فيديو قصير (15 ثانية) - معرض عمل</label>
                            <span class="field-hint">الحد الأقصى لحجم الفيديو: 50 ميجابايت. صيغ مقبولة: MP4، MOV</span>
                            <div class="image-upload" id="videoUpload">
                                <span>🎥 اضغطي لرفع فيديو</span>
                                <input type="file" id="videoFile" accept="video/mp4,video/quicktime" style="display:none;">
                            </div>
                            <span id="videoError" class="field-error-msg" style="display:none;"></span>
                            <div id="videoPreview"></div>
                        </div>
                    </div>
                    
                    <div class="step-buttons">
                        <button type="button" class="btn-prev" onclick="prevStep()">→ السابق</button>
                        <button type="button" class="btn-next" onclick="nextStep()">التالي →</button>
                    </div>
                </div>
                
                <!-- Step 3: الموقع والعنوان -->
                <div class="form-step" data-step="3">
                    <div class="form-section">
                        <h2>📍 العنوان والموقع</h2>
                        <div class="location-row">
                            <div class="form-group">
                                <label>الولاية <span class="required">*</span></label>
                                <select id="wilaya"></select>
                            </div>
                            <div class="form-group">
                                <label>الدائرة</label>
                                <select id="daira" disabled></select>
                            </div>
                        </div>
                        <div class="location-row">
                            <div class="form-group">
                                <label>البلدية <span class="required">*</span></label>
                                <select id="baladiyah" disabled></select>
                            </div>
                        </div>
                        <span id="locationError" class="field-error-msg" style="display:none;"></span>
                        <div class="form-group">
                            <label>وصف العنوان (لا يتعدى 100 كلمة)</label>
                            <textarea id="addressDesc" rows="2" maxlength="500" placeholder="مثال: بجانب مسجد السلام، مقابل العيادة المتعددة الخدمات"></textarea>
                        </div>
                        <div class="form-group">
                            <label>موقع Google Maps (اختياري)</label>
                            <input type="text" id="mapLocation" placeholder="الصق رابط أو إحداثيات الموقع">
                        </div>
                        <div class="form-group" id="travelRangeGroup" style="display:none;">
                            <label>مدى التنقل (كم) - للحلاقات المتنقلات فقط</label>
                            <input type="number" id="travelRange" min="1" max="100" placeholder="مثال: 10">
                        </div>
                        <div class="form-group">
                            <label><input type="checkbox" id="isMixte"> صالون مختلط (يوجد رجال حلاقون)</label>
                        </div>
                    </div>
                    
                    <div class="step-buttons">
                        <button type="button" class="btn-prev" onclick="prevStep()">→ السابق</button>
                        <button type="button" class="btn-next" onclick="nextStep()">التالي →</button>
                    </div>
                </div>
                
                <!-- Step 4: التوثيق -->
                <div class="form-step" data-step="4">
                    <div class="form-section">
                        <h2>🆔 توثيق الهوية (إلزامي)</h2>
                        <div class="form-group">
                            <label>صورة الوجه من بطاقة الهوية الوطنية <span class="required">*</span></label>
                            <div class="image-upload" id="idFrontUpload">
                                <span>📷 اضغطي لرفع الصورة</span>
                                <input type="file" id="idFrontFile" accept="image/jpeg,image/png,image/webp" style="display:none;">
                            </div>
                            <div class="image-preview" id="idFrontPreview"></div>
                        </div>
                        <div class="form-group">
                            <label>صورة ظهر بطاقة الهوية الوطنية <span class="required">*</span></label>
                            <div class="image-upload" id="idBackUpload">
                                <span>📷 اضغطي لرفع الصورة</span>
                                <input type="file" id="idBackFile" accept="image/jpeg,image/png,image/webp" style="display:none;">
                            </div>
                            <div class="image-preview" id="idBackPreview"></div>
                        </div>
                        <span id="idError" class="field-error-msg" style="display:none;"></span>
                    </div>
                    
                    <div class="form-section">
                        <h2>🏪 توثيق إضافي (اختياري - للحصول على علامة موثوق)</h2>
                        <div class="form-group">
                            <label>رقمنة السجل التجاري (للصالونات فقط)</label>
                            <div class="image-upload" id="commercialUpload">
                                <span>📷 اضغطي لرفع السجل التجاري</span>
                                <input type="file" id="commercialFile" accept="image/jpeg,image/png,image/webp" style="display:none;">
                            </div>
                            <div class="image-preview" id="commercialPreview"></div>
                        </div>
                    </div>
                    
                    <div class="step-buttons">
                        <button type="button" class="btn-prev" onclick="prevStep()">→ السابق</button>
                        <button type="submit" class="btn-submit" id="submitBtn" disabled>✨ تقديم الطلب</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="../js/debug.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="../js/supabase.js"></script>
<script src="../js/auth.js"></script>
<script src="../js/utils.js"></script>
<script src="../js/lang.js"></script>
<script>
    // بيانات الولايات والدوائر والبلديات
    let wilayasData = [];
    let dairasData = {};
    let baladiyahsData = {};
    
    let currentStep = 1;
    const totalSteps = 4;

    // تتبع اكتمال كل خطوة
    const stepCompleted = { 1: false, 2: false, 3: false, 4: false };
    
    // رفع الصور مؤقتاً
    let uploadedFiles = {
        logo: null,
        gallery: [],
        video: null,
        idFront: null,
        idBack: null,
        commercial: null
    };

    // =====================================
    // دوال ضغط الصور
    // =====================================
    async function compressImage(file, maxSize = 1024, quality = 0.82) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = function () {
                let w = img.width;
                let h = img.height;
                if (w > maxSize) { h = Math.round((h * maxSize) / w); w = maxSize; }
                if (h > maxSize) { w = Math.round((w * maxSize) / h); h = maxSize; }
                const canvas = document.createElement('canvas');
                canvas.width = w;
                canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                canvas.toBlob(blob => {
                    if (blob) resolve(blob);
                    else reject(new Error('Compression failed'));
                }, 'image/jpeg', quality);
            };
            img.onerror = () => reject(new Error('Image load error'));
            img.src = URL.createObjectURL(file);
        });
    }

    // =====================================
    // التحقق من صحة اسم الصالون
    // =====================================
    function validateBusinessName(name) {
        const el = document.getElementById('businessNameError');
        if (!name || name.trim().length === 0) {
            showFieldErr(el, 'اسم الصالون لا يمكن أن يكون فارغاً.');
            return false;
        }
        if (name.trim().length < 3) {
            showFieldErr(el, 'اسم الصالون يجب أن يحتوي على 3 حروف على الأقل.');
            return false;
        }
        if (name.trim().length > 50) {
            showFieldErr(el, 'اسم الصالون يجب ألا يتجاوز 50 حرفاً.');
            return false;
        }
        // حروف عربية/لاتينية، أرقام، مسافات، شرطة، نقطة فقط
        const nameRegex = /^[a-zA-Z0-9\u0600-\u06FF\s\-\.]{3,50}$/;
        if (!nameRegex.test(name.trim())) {
            showFieldErr(el, 'اسم الصالون يحتوي على رموز غير مسموح بها. استخدمي حروفاً وأرقاماً ومسافات فقط.');
            return false;
        }
        if (window.utils && (window.utils.containsProfanity(name, 'ar') || window.utils.containsProfanity(name, 'fr'))) {
            showFieldErr(el, 'اسم الصالون يحتوي على كلمات غير لائقة.');
            return false;
        }
        hideFieldErr(el);
        return true;
    }

    // =====================================
    // التحقق من رقم الهاتف
    // =====================================
    function validatePhone(value, errorId) {
        const el = document.getElementById(errorId);
        if (!value || value.trim() === '') {
            hideFieldErr(el);
            return true; // الحقل اختياري
        }
        // نقبل فقط أرقام وطولها 10 تبدأ بـ 05/06/07
        const cleaned = value.replace(/\D/g, '');
        if (!/^(05|06|07)\d{8}$/.test(cleaned)) {
            showFieldErr(el, 'رقم الهاتف يجب أن يكون رقماً جزائرياً صحيحاً (05/06/07 + 8 أرقام).');
            return false;
        }
        hideFieldErr(el);
        return true;
    }

    // =====================================
    // التحقق من روابط التواصل الاجتماعي
    // =====================================
    const allowedDomains = {
        instagram: ['instagram.com', 'www.instagram.com'],
        tiktok:    ['tiktok.com', 'www.tiktok.com'],
        facebook:  ['facebook.com', 'www.facebook.com', 'fb.com', 'www.fb.com']
    };

    function validateSocialUrl(value, platform, errorId) {
        const el = document.getElementById(errorId);
        if (!value || value.trim() === '') {
            hideFieldErr(el);
            return true; // الحقل اختياري
        }
        let parsed;
        try {
            parsed = new URL(value.trim());
        } catch {
            showFieldErr(el, 'الرابط غير صالح. تأكدي أنه يبدأ بـ https://');
            return false;
        }
        if (parsed.protocol !== 'https:') {
            showFieldErr(el, 'الرابط يجب أن يبدأ بـ https://');
            return false;
        }
        const hostname = parsed.hostname.toLowerCase();
        if (!allowedDomains[platform].includes(hostname)) {
            showFieldErr(el, `الرابط يجب أن يكون من موقع ${platform} الرسمي فقط.`);
            return false;
        }
        hideFieldErr(el);
        return true;
    }

    // =====================================
    // دوال مساعدة لعرض/إخفاء الأخطاء
    // =====================================
    function showFieldErr(el, msg) {
        if (!el) return;
        el.textContent = msg;
        el.style.display = 'block';
    }
    function hideFieldErr(el) {
        if (!el) return;
        el.textContent = '';
        el.style.display = 'none';
    }

    // =====================================
    // تحميل البيانات الجغرافية
    // =====================================
    async function loadGeoData() {
    try {
        const response = await fetch('../assets/data/wilayas.json');
        wilayasData = await response.json();
        
        const wilayaSelect = document.getElementById('wilaya');
        const defaultOpt = document.createElement('option');
        defaultOpt.value = '';
        defaultOpt.textContent = 'اختر الولاية';
        wilayaSelect.appendChild(defaultOpt);
        
        wilayasData.forEach(w => {
            const option = document.createElement('option');
            option.value = w.code;
            option.textContent = w.name_ar;
            wilayaSelect.appendChild(option);
        });
        
        wilayaSelect.addEventListener('change', loadDairas);
    } catch (error) {
        console.error('Error loading geo data:', error);
    }
}

async function loadDairas() {
    const wilayaCode = document.getElementById('wilaya').value;
    if (!wilayaCode) return;
    
    try {
        const response = await fetch('../assets/data/dairas.json');
        const allDairas = await response.json();
        dairasData = allDairas[wilayaCode] || [];
        
        const dairaSelect = document.getElementById('daira');
        dairaSelect.innerHTML = '<option value="">اختر الدائرة</option>';
        dairaSelect.disabled = false;
        
        dairasData.forEach(d => {
            const option = document.createElement('option');
            option.value = d.code;
            option.textContent = d.name_ar;
            dairaSelect.appendChild(option);
        });
        
        dairaSelect.addEventListener('change', loadBaladiyahs);
    } catch (error) {
        console.error('Error loading dairas:', error);
    }
}

async function loadBaladiyahs() {
    const dairaCode = document.getElementById('daira').value;
    if (!dairaCode) return;
    
    try {
        const response = await fetch('../assets/data/baladiyahs.json');
        const allBaladiyahs = await response.json();
        baladiyahsData = allBaladiyahs[dairaCode] || [];
        
        const baladiyahSelect = document.getElementById('baladiyah');
        baladiyahSelect.innerHTML = '<option value="">اختر البلدية</option>';
        baladiyahSelect.disabled = false;
        
        baladiyahsData.forEach(b => {
            const option = document.createElement('option');
            option.value = b.code;
            option.textContent = b.name_ar;
            baladiyahSelect.appendChild(option);
        });
    } catch (error) {
        console.error('Error loading baladiyahs:', error);
    }
}
    
    function toggleTravelRange() {
        const services = getSelectedServices();
        const showTravel = services.includes('mobile_hair');
        document.getElementById('travelRangeGroup').style.display = showTravel ? 'block' : 'none';
    }
    
    function getSelectedServices() {
        const checkboxes = document.querySelectorAll('#servicesGroup input:checked');
        return Array.from(checkboxes).map(cb => cb.value);
    }
    
    function updateBioCount() {
        const bio = document.getElementById('bio');
        const count = bio.value.length;
        document.getElementById('bioCount').textContent = `${count} / 500`;
        if (count > 500) bio.value = bio.value.slice(0, 500);
    }
    
    // =====================================
    // معالجة رفع الصور مع ضغط
    // =====================================
    function setupImageUploads() {
        setupUpload('logoUpload',       'logoFile',       'logoPreview',       'logo',       false, true);
        setupUpload('galleryUpload',    'galleryFiles',   'galleryPreview',    'gallery',    true,  true);
        setupUpload('videoUpload',      'videoFile',      'videoPreview',      'video',      false, false);
        setupUpload('idFrontUpload',    'idFrontFile',    'idFrontPreview',    'idFront',    false, true);
        setupUpload('idBackUpload',     'idBackFile',     'idBackPreview',     'idBack',     false, true);
        setupUpload('commercialUpload', 'commercialFile', 'commercialPreview', 'commercial', false, true);
    }
    
    function setupUpload(uploadId, fileInputId, previewId, key, multiple = false, isImage = true) {
        const uploadDiv  = document.getElementById(uploadId);
        const fileInput  = document.getElementById(fileInputId);
        const previewDiv = document.getElementById(previewId);
        
        uploadDiv.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', async (e) => {
            const files = Array.from(e.target.files);
            if (!files.length) return;
            previewDiv.innerHTML = '';

            if (!isImage) {
                // فيديو — التحقق من الحجم
                const videoError = document.getElementById('videoError');
                const file = files[0];
                const maxVideoSize = 50 * 1024 * 1024; // 50MB
                if (file.size > maxVideoSize) {
                    showFieldErr(videoError, 'حجم الفيديو يتجاوز الحد المسموح به (50 ميجابايت). اختاري فيديو أصغر.');
                    fileInput.value = '';
                    uploadedFiles[key] = null;
                    return;
                }
                hideFieldErr(videoError);
                uploadedFiles[key] = file;
                // معاينة الفيديو
                const video = document.createElement('video');
                video.src = URL.createObjectURL(file);
                video.controls = true;
                video.style.cssText = 'max-width:100%; border-radius:8px; margin-top:10px;';
                previewDiv.appendChild(video);
                return;
            }

            // صور — ضغط قبل التخزين المؤقت
            if (multiple) {
                const compressed = [];
                for (const file of files) {
                    try {
                        const blob = await compressImage(file, 1200, 0.82);
                        compressed.push(blob);
                        const img = document.createElement('img');
                        img.src = URL.createObjectURL(blob);
                        previewDiv.appendChild(img);
                    } catch { /* تجاهل الملفات الفاسدة */ }
                }
                uploadedFiles[key] = compressed;
            } else {
                try {
                    const blob = await compressImage(files[0], 1200, 0.82);
                    uploadedFiles[key] = blob;
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(blob);
                    previewDiv.appendChild(img);
                } catch {
                    uploadedFiles[key] = null;
                }
            }
        });
    }

    // =====================================
    // التحقق من كل خطوة قبل الانتقال
    // =====================================
    function validateStep(step) {
        if (step === 1) {
            const services = getSelectedServices();
            const el = document.getElementById('servicesError');
            if (services.length === 0) {
                showFieldErr(el, 'الرجاء اختيار نوع الخدمات التي تقدمينها.');
                return false;
            }
            hideFieldErr(el);
            return true;
        }

        if (step === 2) {
            const businessName = document.getElementById('businessName').value.trim();
            const username     = document.getElementById('username').value.trim();
            const bio          = document.getElementById('bio').value.trim();
            const phone        = document.getElementById('phone').value.trim();
            const whatsapp     = document.getElementById('whatsapp').value.trim();
            const instagram    = document.getElementById('instagram').value.trim();
            const tiktok       = document.getElementById('tiktok').value.trim();
            const facebook     = document.getElementById('facebook').value.trim();

            let valid = true;

            if (!validateBusinessName(businessName)) valid = false;

            // التحقق من اسم المستخدم
            const usernameEl = document.getElementById('usernameError');
            if (!username) {
                showFieldErr(usernameEl, 'اسم المستخدم مطلوب.');
                valid = false;
            } else if (!utils.isValidUsername(username)) {
                showFieldErr(usernameEl, 'اسم المستخدم يجب أن يكون 3-30 حرفاً (أحرف، أرقام، شرطة سفلية فقط). لا مسافات.');
                valid = false;
            } else {
                hideFieldErr(usernameEl);
            }

            // التحقق من الـ BIO
            const bioEl = document.getElementById('bioError');
            if (!bio) {
                showFieldErr(bioEl, 'الوصف مطلوب.');
                valid = false;
            } else {
                hideFieldErr(bioEl);
            }

            if (!validatePhone(phone,    'phoneError'))     valid = false;
            if (!validatePhone(whatsapp, 'whatsappError'))  valid = false;
            if (!validateSocialUrl(instagram, 'instagram', 'instagramError')) valid = false;
            if (!validateSocialUrl(tiktok,    'tiktok',    'tiktokError'))    valid = false;
            if (!validateSocialUrl(facebook,  'facebook',  'facebookError'))  valid = false;

            return valid;
        }

        if (step === 3) {
            const wilaya    = document.getElementById('wilaya').value;
            const baladiyah = document.getElementById('baladiyah').value;
            const el        = document.getElementById('locationError');
            if (!wilaya) {
                showFieldErr(el, 'الرجاء اختيار الولاية.');
                return false;
            }
            if (!baladiyah) {
                showFieldErr(el, 'الرجاء اختيار البلدية.');
                return false;
            }
            hideFieldErr(el);
            return true;
        }

        if (step === 4) {
            const el = document.getElementById('idError');
            if (!uploadedFiles.idFront || !uploadedFiles.idBack) {
                showFieldErr(el, 'الرجاء رفع صور بطاقة الهوية (الوجه والظهر).');
                return false;
            }
            hideFieldErr(el);
            return true;
        }

        return true;
    }

    // =====================================
    // تحديث شريط التقدم
    // =====================================
    function updateProgressBar() {
        for (let i = 1; i <= totalSteps; i++) {
            const step = document.querySelector(`.progress-step[data-step="${i}"]`);
            if (i < currentStep) {
                step.classList.add('completed');
                step.classList.remove('active');
                // إخفاء الرقم وإظهار ✓ عبر CSS ::after
                step.querySelector('.step-number').textContent = '';
            } else if (i === currentStep) {
                step.classList.add('active');
                step.classList.remove('completed');
                step.querySelector('.step-number').textContent = i;
            } else {
                step.classList.remove('active', 'completed');
                step.querySelector('.step-number').textContent = i;
            }
        }
        
        document.querySelectorAll('.form-step').forEach(step => {
            step.classList.remove('active-step');
            if (parseInt(step.dataset.step) === currentStep) {
                step.classList.add('active-step');
            }
        });

        // تحديث حالة زر الإرسال
        updateSubmitBtn();
    }

    // =====================================
    // تحديث زر الإرسال (disabled إذا لم تكتمل الخطوات)
    // =====================================
    function updateSubmitBtn() {
        const btn = document.getElementById('submitBtn');
        if (!btn) return;
        const allDone = stepCompleted[1] && stepCompleted[2] && stepCompleted[3] && stepCompleted[4];
        btn.disabled = !allDone;
    }
    
    window.nextStep = function() {
        if (!validateStep(currentStep)) return;

        // تعليم الخطوة الحالية كمكتملة
        stepCompleted[currentStep] = true;

        if (currentStep < totalSteps) {
            currentStep++;
            updateProgressBar();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // إذا وصلنا الخطوة 4 تحقق أيضاً منها لتفعيل الزر فوراً إن كانت مكتملة
        if (currentStep === 4) {
            stepCompleted[4] = validateStep(4);
            updateSubmitBtn();
        }
    };
    
    window.prevStep = function() {
        if (currentStep > 1) {
            currentStep--;
            updateProgressBar();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    };
    
    // =====================================
    // إرسال النموذج
    // =====================================
    async function submitRegistration(e) {
        e.preventDefault();

        // تحقق نهائي من كل الخطوات
        for (let s = 1; s <= 4; s++) {
            if (!validateStep(s)) {
                if (window.utils) window.utils.showToast(`يوجد خطأ في الخطوة ${s}، الرجاء مراجعتها.`, 'error');
                return;
            }
        }

        const businessName = DOMPurify.sanitize(document.getElementById('businessName').value.trim());
        const username     = document.getElementById('username').value.trim();
        const bio          = DOMPurify.sanitize(document.getElementById('bio').value.trim());
        const phone        = document.getElementById('phone').value.replace(/\D/g, '') || null;
        const whatsapp     = document.getElementById('whatsapp').value.replace(/\D/g, '') || null;
        const instagram    = document.getElementById('instagram').value.trim() || null;
        const tiktok       = document.getElementById('tiktok').value.trim() || null;
        const facebook     = document.getElementById('facebook').value.trim() || null;
        const wilaya       = document.getElementById('wilaya').value;
        const baladiyah    = document.getElementById('baladiyah').value;
        const subscription = document.querySelector('input[name="subscription"]:checked')?.value || 'silver';
        const services     = getSelectedServices();
        
        if (window.utils) window.utils.showToast('جاري رفع المستندات...', 'info');

        // هنا يتم رفع الملفات الفعلي إلى Supabase Storage وحفظ البيانات
        // uploadedFiles.logo, uploadedFiles.gallery, uploadedFiles.video,
        // uploadedFiles.idFront, uploadedFiles.idBack, uploadedFiles.commercial
        // مضغوطة مسبقاً (الصور) أو جاهزة للرفع (الفيديو)

        if (window.utils) window.utils.showToast('تم إرسال طلب التسجيل بنجاح! سيتم مراجعة حسابك وإشعارك عند القبول.', 'success');
        
        setTimeout(() => {
            window.location.href = '../index.html';
        }, 3000);
    }
    
    // =====================================
    // التهيئة
    // =====================================
    document.addEventListener('DOMContentLoaded', () => {
        loadGeoData();
        setupImageUploads();
        
        document.getElementById('bio').addEventListener('input', updateBioCount);
        document.getElementById('servicesGroup').addEventListener('change', toggleTravelRange);
        document.getElementById('businessRegisterForm').addEventListener('submit', submitRegistration);

        // تحقق فوري عند مغادرة حقل الهاتف والواتساب
        document.getElementById('phone').addEventListener('blur', () => {
            validatePhone(document.getElementById('phone').value, 'phoneError');
        });
        document.getElementById('whatsapp').addEventListener('blur', () => {
            validatePhone(document.getElementById('whatsapp').value, 'whatsappError');
        });
        document.getElementById('instagram').addEventListener('blur', () => {
            validateSocialUrl(document.getElementById('instagram').value, 'instagram', 'instagramError');
        });
        document.getElementById('tiktok').addEventListener('blur', () => {
            validateSocialUrl(document.getElementById('tiktok').value, 'tiktok', 'tiktokError');
        });
        document.getElementById('facebook').addEventListener('blur', () => {
            validateSocialUrl(document.getElementById('facebook').value, 'facebook', 'facebookError');
        });

        // مراقبة رفع هوية الخطوة 4 لتحديث زر الإرسال
        document.getElementById('idFrontFile').addEventListener('change', () => {
            stepCompleted[4] = validateStep(4);
            updateSubmitBtn();
        });
        document.getElementById('idBackFile').addEventListener('change', () => {
            stepCompleted[4] = validateStep(4);
            updateSubmitBtn();
        });
        
        if (typeof particles !== 'undefined') {
            particles.init();
        }
    });
</script>
</body>
</html>
