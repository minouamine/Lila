    // ========================================
    // عرض قائمة النتائج
    // ========================================
    function renderListView() {
        const container = document.getElementById('listView');
        const currentLang = window.lang ? window.lang.getCurrentLang() : 'ar';
        
        if (!results || results.length === 0) {
            container.innerHTML = `
                <div class="no-results">
                    <div class="no-results-icon">🛍️</div>
                    <h3 data-ar="لا توجد نتائج" data-fr="Aucun résultat">لا توجد نتائج</h3>
                    <p data-ar="لم نعثر على بائعات منتجات في هذه المنطقة" data-fr="Aucune vendeuse de produits dans cette région">لم نعثر على بائعات منتجات في هذه المنطقة</p>
                    <button onclick="document.getElementById('searchBtn').click()" style="margin-top:15px;padding:8px 20px;background:var(--accent-orange);border:none;border-radius:8px;color:white;cursor:pointer;" data-ar="بحث جديد" data-fr="Nouvelle recherche">بحث جديد</button>
                </div>
            `;
            if (window.lang) window.lang.updateAllTranslations();
            return;
        }
        
        const categoryNames = {
            ar: {
                cosmetics: '💄 مستحضرات تجميل',
                perfumes: '🌸 عطور',
                supplements: '💊 مكملات غذائية',
                tools: '✂️ أدوات عناية'
            },
            fr: {
                cosmetics: '💄 Cosmétiques',
                perfumes: '🌸 Parfums',
                supplements: '💊 Compléments alimentaires',
                tools: '✂️ Outils de soin'
            }
        };
        
        container.innerHTML = results.map(business => {
            const ratingStars = '★'.repeat(Math.floor(business.avg_rating || 0)) + '☆'.repeat(5 - Math.floor(business.avg_rating || 0));
            const langCategoryNames = currentLang === 'fr' ? categoryNames.fr : categoryNames.ar;
            
            return `
                <div class="product-card" onclick="window.location.href='business-profile.html?id=${business.id}'">
                    <img class="product-image" src="${business.logo_url || '../assets/images/default-business.png'}" onerror="this.src='https://via.placeholder.com/300x180?text=Produits'" alt="${business.business_name}">
                    <div class="product-name">
                        ${DOMPurify.sanitize(business.business_name)}
                        ${business.has_gold_badge ? '<span class="gold-badge">⭐ ' + (currentLang === 'fr' ? 'Certifié' : 'موثوق') + '</span>' : ''}
                        ${business.is_online ? '<span class="online-badge">🟢 ' + (currentLang === 'fr' ? 'Disponible' : 'متاحة الآن') + '</span>' : ''}
                    </div>
                    <div class="product-rating">
                        <span class="stars">${ratingStars}</span>
                        <span>(${business.reviews_count || 0})</span>
                    </div>
                    <div class="product-category">
                        ${(business.product_categories || ['cosmetics']).slice(0, 2).map(c => `<span class="category-tag">${langCategoryNames[c] || c}</span>`).join('')}
                    </div>
                    <div class="product-location">📍 ${business.wilaya_name || (currentLang === 'fr' ? 'Wilaya non spécifiée' : 'ولاية غير محددة')}</div>
                    <div class="product-followers">👥 ${business.followers_count || 0} ${currentLang === 'fr' ? 'abonné(e)s' : 'متابع'}</div>
                    ${business.distance ? `<div class="product-distance">📍 ${business.distance.toFixed(1)} ${currentLang === 'fr' ? 'km' : 'كم'}</div>` : ''}
                </div>
            `;
        }).join('');
    }
    
    // ========================================
    // عرض الخريطة
    // ========================================
    function renderMapView() {
        const mapContainer = document.getElementById('mapView');
        
        if (!mapContainer) return;
        
        // تهيئة الخريطة إذا لم تكن موجودة
        if (!map) {
            map = L.map('mapView').setView([36.7538, 3.0588], 6);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>',
                subdomains: 'abcd'
            }).addTo(map);
        }
        
        // إزالة العلامات القديمة
        markers.forEach(marker => map.removeLayer(marker));
        markers = [];
        
        // إضافة علامات جديدة
        let bounds = null;
        
        results.forEach(business => {
            if (business.latitude && business.longitude) {
                // أيقونة مخصصة لبائعات المنتجات (وردية)
                const productIcon = L.divIcon({
                    html: `<div style="background: #f472b6; width: 14px; height: 14px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 5px rgba(0,0,0,0.5);"></div>`,
                    iconSize: [14, 14],
                    className: 'product-marker'
                });
                
                const marker = L.marker([business.latitude, business.longitude], { icon: productIcon })
                    .bindPopup(`
                        <div style="text-align: center; min-width: 180px;">
                            <img src="${business.logo_url || '../assets/images/default-business.png'}" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-bottom: 8px;" onerror="this.src='https://via.placeholder.com/50'">
                            <h4 style="margin: 5px 0;">${DOMPurify.sanitize(business.business_name)}</h4>
                            <div style="color: gold;">⭐ ${business.avg_rating || 0}</div>
                            <div style="font-size: 0.8rem;">🛍️ ${window.lang && window.lang.getCurrentLang() === 'fr' ? 'Vendeuse de produits' : 'بائعة منتجات'}</div>
                            <a href="business-profile.html?id=${business.id}" style="display: inline-block; margin-top: 8px; color: #ff8c00; text-decoration: none;">${window.lang && window.lang.getCurrentLang() === 'fr' ? 'Voir détails →' : 'عرض التفاصيل →'}</a>
                        </div>
                    `)
                    .addTo(map);
                markers.push(marker);
                
                if (!bounds) {
                    bounds = L.latLngBounds([business.latitude, business.longitude]);
                } else {
                    bounds.extend([business.latitude, business.longitude]);
                }
            }
        });
        
        // توسيع الخريطة لتناسب جميع العلامات
        if (bounds && markers.length > 0) {
            map.fitBounds(bounds.pad(0.1));
        } else if (userLocation) {
            map.setView([userLocation.lat, userLocation.lng], 10);
        } else {
            map.setView([36.7538, 3.0588], 6);
        }
    }
    
    // ========================================
    // تبديل عرض القائمة / الخريطة
    // ========================================
    function initViewToggle() {
        const listView = document.getElementById('listView');
        const mapView = document.getElementById('mapView');
        
        document.querySelectorAll('.view-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const view = btn.getAttribute('data-view');
                
                document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                if (view === 'list') {
                    listView.classList.add('active');
                    mapView.classList.remove('active');
                } else {
                    listView.classList.remove('active');
                    mapView.classList.add('active');
                    setTimeout(() => {
                        if (map) map.invalidateSize();
                    }, 100);
                }
            });
        });
    }
    
    // ========================================
    // مودال المطور
    // ========================================
    function initDevModal() {
        const devModal = document.getElementById('devModal');
        const openBtn = document.getElementById('openDevBtn');
        const closeBtn = document.getElementById('closeModalBtn');
        
        if (openBtn) openBtn.addEventListener('click', () => devModal.classList.add('show'));
        if (closeBtn) closeBtn.addEventListener('click', () => devModal.classList.remove('show'));
        if (devModal) devModal.addEventListener('click', e => { if (e.target === devModal) devModal.classList.remove('show'); });
    }
    
    // ========================================
    // موسيقى الخلفية
    // ========================================
    function initMusicToggle() {
        const musicBtn = document.getElementById('musicToggleBtn');
        let audio = null;
        let playing = false;
        
        if (musicBtn) {
            musicBtn.addEventListener('click', () => {
                if (!audio) {
                    audio = new Audio('../assets/music/bg.mp3');
                    audio.loop = true;
                    audio.volume = 0.3;
                }
                if (playing) {
                    audio.pause();
                    musicBtn.textContent = '🔇';
                } else {
                    audio.play().catch(() => {});
                    musicBtn.textContent = '🔊';
                }
                playing = !playing;
            });
        }
    }
    
    // ========================================
    // التهيئة عند تحميل الصفحة
    // ========================================
    async function initPage() {
        // تحميل قائمة الولايات
        await loadWilayas();
        
        // الحصول على موقع المستخدم
        getUserLocation();
        
        // تهيئة أزرار التبديل
        initViewToggle();
        
        // تهيئة مودال المطور
        initDevModal();
        
        // تهيئة زر الموسيقى
        initMusicToggle();
        
        // تهيئة زر البحث
        document.getElementById('searchBtn').addEventListener('click', performSearch);
        
        // الاستماع لتغيير اللغة
        if (window.lang) {
            window.lang.addLangListener(() => {
                updateLanguageForSelects();
                renderListView();
                if (window.lang.updateAllTranslations) window.lang.updateAllTranslations();
            });
        }
        
        // تنفيذ بحث أولي
        await performSearch();
        
        // تحديث الترجمة
        if (window.lang) {
            window.lang.updateAllTranslations();
        }
        
        // تهيئة الجسيمات
        if (window.particles && typeof window.particles.init === 'function') {
            window.particles.init();
        }
        
        console.log('[Products] Page initialized successfully');
    }
    
    // تشغيل التهيئة عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', initPage);
</script>
</body>
</html>